<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="using:FluentAvalonia.UI.Controls"
             x:Class="SekaiToolsApp.Views.Pages.PlaceholderPage">

    <Border Padding="32">
        <StackPanel Spacing="12" HorizontalAlignment="Center" VerticalAlignment="Center">
            <ui:SymbolIcon x:Name="IconView" FontSize="64" HorizontalAlignment="Center"/>
            <TextBlock x:Name="TitleView" FontSize="22" FontWeight="SemiBold" HorizontalAlignment="Center"/>
            <TextBlock x:Name="DescriptionView" Opacity="0.7" HorizontalAlignment="Center"
                       TextWrapping="Wrap" MaxWidth="520" TextAlignment="Center"/>
            <TextBlock x:Name="MigrationHintView" Opacity="0.5" FontSize="12"
                       HorizontalAlignment="Center" TextAlignment="Center"/>
        </StackPanel>
    </Border>
</UserControl>

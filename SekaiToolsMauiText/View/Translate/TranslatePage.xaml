<?xml version="1.0" encoding="utf-8"?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:views="clr-namespace:SekaiToolsMauiText.View.Translate"
             xmlns:components="clr-namespace:SekaiToolsMauiText.View.Translate.Components"
             x:Class="SekaiToolsMauiText.View.Translate.TranslatePage"
             Title="翻译工作台">

    <ContentPage.Resources>
        <DataTemplate x:Key="DialogTemplate">
            <components:TranslateLineDialog />
        </DataTemplate>
        <DataTemplate x:Key="EffectTemplate">
            <components:TranslateLineEffect />
        </DataTemplate>
        <views:LineModelTemplateSelector x:Key="LineModelSelector"
                                         DialogTemplate="{StaticResource DialogTemplate}"
                                         EffectTemplate="{StaticResource EffectTemplate}" />
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,*" Margin="8">
        <ScrollView Grid.Row="0"
                    Orientation="Vertical"
                    MaximumHeightRequest="340">
            <VerticalStackLayout Spacing="8">
                <Border Stroke="{AppThemeBinding Light=#CCCCCC, Dark=#555555}"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 8"
                        Padding="10">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="SekaiPlatform"
                               FontAttributes="Bold"
                               FontSize="16" />
                        <Grid ColumnDefinitions="110,*"
                              RowDefinitions="Auto,Auto,Auto,Auto,Auto">
                            <Label Grid.Row="0"
                                   Text="平台地址"
                                   VerticalOptions="Center" />
                            <Entry Grid.Row="0"
                                   Grid.Column="1"
                                   Text="{Binding BaseUrl, Mode=TwoWay}"
                                   Placeholder="http://localhost:8080" />

                            <Label Grid.Row="1"
                                   Text="用户名"
                                   VerticalOptions="Center" />
                            <Entry Grid.Row="1"
                                   Grid.Column="1"
                                   Text="{Binding Username, Mode=TwoWay}" />

                            <Label Grid.Row="2"
                                   Text="密码"
                                   VerticalOptions="Center" />
                            <Entry Grid.Row="2"
                                   Grid.Column="1"
                                   Text="{Binding Password, Mode=TwoWay}"
                                   IsPassword="True" />

                            <Label Grid.Row="3"
                                   Text="当前会话"
                                   VerticalOptions="Center" />
                            <Label Grid.Row="3"
                                   Grid.Column="1"
                                   Text="{Binding SessionText}" />

                            <Label Grid.Row="4"
                                   Text="当前租户"
                                   VerticalOptions="Center" />
                            <Picker Grid.Row="4"
                                    Grid.Column="1"
                                    Title="选择租户"
                                    ItemsSource="{Binding Tenants}"
                                    SelectedItem="{Binding SelectedTenant, Mode=TwoWay}"
                                    ItemDisplayBinding="{Binding Name}" />
                        </Grid>

                        <HorizontalStackLayout Spacing="6">
                            <Button Text="登录"
                                    Clicked="PlatformLoginButton_OnClick" />
                            <Button Text="刷新会话"
                                    Clicked="RefreshSessionButton_OnClick" />
                            <Button Text="切换租户"
                                    Clicked="SwitchTenantButton_OnClick"
                                    IsEnabled="{Binding HasSelectedTenant}" />
                            <Button Text="登出"
                                    Clicked="PlatformLogoutButton_OnClick" />
                        </HorizontalStackLayout>
                    </VerticalStackLayout>
                </Border>

                <Border Stroke="{AppThemeBinding Light=#CCCCCC, Dark=#555555}"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 8"
                        Padding="10">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="平台剧情"
                               FontAttributes="Bold"
                               FontSize="16" />
                        <Grid ColumnDefinitions="110,*"
                              RowDefinitions="Auto,Auto,Auto,Auto">
                            <Label Grid.Row="0"
                                   Text="剧情类型"
                                   VerticalOptions="Center" />
                            <Picker Grid.Row="0"
                                    Grid.Column="1"
                                    Title="选择剧情类型"
                                    ItemsSource="{Binding StoryTypes}"
                                    SelectedItem="{Binding SelectedStoryType, Mode=TwoWay}" />

                            <Label Grid.Row="1"
                                   Text="剧情集"
                                   VerticalOptions="Center" />
                            <Picker Grid.Row="1"
                                    Grid.Column="1"
                                    Title="选择剧情集"
                                    ItemsSource="{Binding StoryGroups}"
                                    SelectedItem="{Binding SelectedStoryGroup, Mode=TwoWay}"
                                    ItemDisplayBinding="{Binding DisplayLabel}"
                                    SelectedIndexChanged="StoryGroupPicker_OnSelectedIndexChanged" />

                            <Label Grid.Row="2"
                                   Text="剧情"
                                   VerticalOptions="Center" />
                            <Picker Grid.Row="2"
                                    Grid.Column="1"
                                    Title="选择剧情"
                                    ItemsSource="{Binding Stories}"
                                    SelectedItem="{Binding SelectedStory, Mode=TwoWay}"
                                    ItemDisplayBinding="{Binding DisplayLabel}"
                                    SelectedIndexChanged="StoryPicker_OnSelectedIndexChanged" />

                            <Label Grid.Row="3"
                                   Text="平台版本"
                                   VerticalOptions="Center" />
                            <Picker Grid.Row="3"
                                    Grid.Column="1"
                                    Title="选择译文版本"
                                    ItemsSource="{Binding TranslationVersions}"
                                    SelectedItem="{Binding SelectedTranslationVersion, Mode=TwoWay}"
                                    ItemDisplayBinding="{Binding DisplayLabel}" />
                        </Grid>

                        <HorizontalStackLayout Spacing="6">
                            <Button Text="刷新类型"
                                    Clicked="RefreshStoryTypesButton_OnClick" />
                            <Button Text="加载剧情集"
                                    Clicked="LoadStoryGroupsButton_OnClick"
                                    IsEnabled="{Binding HasSelectedStoryType}" />
                            <Button Text="加载剧情"
                                    Clicked="LoadPlatformStoryButton_OnClick"
                                    IsEnabled="{Binding HasSelectedStory}" />
                            <Button Text="载入平台译文"
                                    Clicked="LoadPlatformTranslationButton_OnClick"
                                    IsEnabled="{Binding HasSelectedTranslationVersion}" />
                            <Button Text="载入平台对照"
                                    Clicked="LoadPlatformReferenceButton_OnClick"
                                    IsEnabled="{Binding HasSelectedTranslationVersion}" />
                        </HorizontalStackLayout>
                    </VerticalStackLayout>
                </Border>

                <Border Stroke="{AppThemeBinding Light=#CCCCCC, Dark=#555555}"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 8"
                        Padding="10">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="本地兼容模式"
                               FontAttributes="Bold"
                               FontSize="16" />
                        <HorizontalStackLayout Spacing="6">
                            <Button x:Name="LoadScriptButton"
                                    Text="载入剧本"
                                    Clicked="LoadScriptButton_OnClick" />
                            <Button x:Name="LoadTranslationButton"
                                    Text="打开翻译"
                                    Clicked="LoadTranslationButton_OnClick"
                                    IsVisible="False" />
                            <Button x:Name="LoadReviewButton"
                                    Text="打开对照翻译"
                                    Clicked="LoadReviewButton_OnClick"
                                    IsVisible="False" />
                        </HorizontalStackLayout>
                    </VerticalStackLayout>
                </Border>

                <Border Stroke="{AppThemeBinding Light=#CCCCCC, Dark=#555555}"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 8"
                        Padding="10">
                    <Grid ColumnDefinitions="110,*"
                          RowDefinitions="Auto,Auto,Auto">
                        <Label Grid.Row="0"
                               Text="当前文档"
                               VerticalOptions="Center" />
                        <Label Grid.Row="0"
                               Grid.Column="1"
                               Text="{Binding CurrentDocumentTitle}" />

                        <Label Grid.Row="1"
                               Text="当前模式"
                               VerticalOptions="Center" />
                        <Label Grid.Row="1"
                               Grid.Column="1"
                               Text="{Binding ModeText}" />

                        <HorizontalStackLayout Grid.Row="2"
                                               Grid.ColumnSpan="2"
                                               Spacing="6"
                                               HorizontalOptions="End">
                            <Button x:Name="ResetButton"
                                    Text="重置"
                                    Clicked="ResetButton_OnClick" />
                            <Button x:Name="SaveButton"
                                    Text="保存到本地"
                                    Clicked="SaveButton_OnClick" />
                            <Button x:Name="UploadButton"
                                    Text="上传到平台"
                                    Clicked="UploadButton_OnClick"
                                    IsEnabled="{Binding CanUploadToPlatform}" />
                        </HorizontalStackLayout>
                    </Grid>
                </Border>
            </VerticalStackLayout>
        </ScrollView>

        <Grid Grid.Row="1"
              ColumnDefinitions="150,*"
              Margin="0,8,0,0">
            <components:FastCopyView Grid.Column="0"
                                     Margin="0,0,6,0" />

            <CollectionView Grid.Column="1"
                            x:Name="TranslatePanel"
                            ItemsSource="{Binding Events}"
                            ItemTemplate="{StaticResource LineModelSelector}"
                            ItemsUpdatingScrollMode="KeepScrollOffset">
                <CollectionView.EmptyView>
                    <VerticalStackLayout VerticalOptions="Center"
                                         HorizontalOptions="Center"
                                         Spacing="12">
                        <Label Text="📄"
                               FontSize="48"
                               HorizontalOptions="Center" />
                        <Label Text="请先从 SekaiPlatform 或本地文件载入剧情"
                               FontSize="16"
                               HorizontalOptions="Center"
                               TextColor="{AppThemeBinding Light=#888888, Dark=#AAAAAA}" />
                    </VerticalStackLayout>
                </CollectionView.EmptyView>
            </CollectionView>
        </Grid>
    </Grid>
</ContentPage>
